TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# Defaults for each user until they configure their own sheet in Telegram (/setup).
TIMEZONE=Europe/Kyiv
DEFAULT_TARGET_KCAL=1800
# Per-user config backend: "firestore" or "filesystem".
# Auto-detects on GCP (Firestore if GOOGLE_CLOUD_PROJECT is set, else filesystem).
USER_CONFIG_BACKEND=
# Firestore settings (only when backend=firestore).
# GOOGLE_CLOUD_PROJECT is usually auto-detected on Cloud Run.
FIRESTORE_COLLECTION=user_configs
# Filesystem fallback directory (only when backend=filesystem, e.g. local dev).
USER_DATA_DIR=user_data
# Webhook mode (required for Cloud Run). Leave empty to use polling instead.
# Set to your Cloud Run service URL, e.g. https://calorie-bot-xxxxx-ew.a.run.app
WEBHOOK_URL=
# Optional secret for validating webhook requests from Telegram.
# If not set, a random token is generated on each startup.
WEBHOOK_SECRET=
